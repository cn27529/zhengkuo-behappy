{
  "name": "zhengkuo-behappy",
  "version": "1.0.0",
  "description": "An zhengkuo-behappy app for eform app",
  "main": "index.js",
  "scripts": {
    "test:mydata": "node scripts/testMydata.js",
    "test:mydata-create": "node scripts/testMydata.js --create",
    "test:wal": "node scripts/stress-test-wal.js",
    "test:query": "node scripts/stress-test-mydata-query.js",
    "test:logs": "cd log-server && node test-complete.js",
    "stress:test": "concurrently \"npm:test:wal\" \"npm:test:query\" ",
    "check:db-locks": "node scripts/check-db-locks-detailed.js",
    "check:symlink": "node scripts/windows-symlink-helper.js",
    "check:logs": "node scripts/check-log-server.js",
    "start:server": "cd server && npm run dev",
    "start:client": "cd client && npm run dev",
    "start:client:dist": "npx http-server dist",
    "start:rust": "cd rust-axum && cargo run",
    "start:logs": "cd log-server && node mongoDBLogger.js",
    "start:portal": "node --watch apps-server.js",
    "start:docs": "cd docs && npm run start",
    "start:backend": "npm run build:backend && cd backend && npm run start",
    "build:client": "cd client && npm run build",
    "build:client:analyze": "cd client && npm run build:analyze",
    "build:server": "cd server && npm run build",
    "build:rust": "cd rust-axum && cargo build",
    "build:docs": "cd docs && node generate-books.js",
    "build:backend": "npm run build:client && cd backend && npm run copy",
    "dev": "concurrently \"npm:start:server\" \"npm:start:client\" \"npm:start:rust\" \"npm:start:logs\" \"npm:start:docs\" \"npm:start:portal\" ",
    "deploy:netlify": "sh scripts/deploy-netlify.sh",
    "db": "node scripts/start-with-db.js",
    "sqlite:viewer": "node scripts/sqlite-viewer.js",
    "all": "node scripts/start-all.js",
    "mock": "node scripts/dataUrlToJson.js && cp -rv mock_data/*.* client/src/data/",
    "pm2": "pm2 start scripts/start-all.js --name \"zk-client\" ",
    "pm2:server": "cd server && pm2 start npm --name \"directus\" -- start ",
    "pm2:rust": "cd rust-axum && pm2 start cargo --name \"rust\" -- run ",
    "pm2:backend": "cd backend && npm run build:backend && pm2 start npm --name \"backend\" -- start ",
    "pm2:client": "cd client && pm2 start npm --name \"backend\" -- start "
  },
  "keywords": [],
  "author": "cn27529",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "express": "^4.22.1",
    "marked": "^12.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "sqlite3": "^5.1.7"
  }
}