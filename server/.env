# Directus JWT 設置
KEY="mT5qR8vW2tZ4cV7bN1mK3jH6gF9dA2sJ5hG8fD1kS4pX7yB0wM3rC6eU9iQ2"
SECRET="xLp9vW2tZ5cV8bN1mK4jH7gF0dA3sJ6hG9fD2kS5pX8yB1wM4rC7eU0iQ3tZ6vN1mK4jH7gF0dA3sJ6hG9fD2kS5pX8yB1wM4rC7eU0iQ3"

# 認證配置，預設15m
#ACCESS_TOKEN_TTL="60m"
#REFRESH_TOKEN_TTL="7d"
ACCESS_TOKEN_TTL="24h"      # 24小時，方便開發測試
REFRESH_TOKEN_TTL="30d"     # 30天

# 資料庫配置（SQLite 範例）
DB_CLIENT="sqlite3"
DB_FILENAME="../db/current.db"  # 指向當前客戶數據庫的符號鏈接，使用`scripts/start-with-db.js`來切換
# 透過連線選項設置 busy_timeout (單位通常是毫秒)
DB_CONNECTION_CONFIG_OPTIONS='{"busy_timeout": 5000}'

# # 設置 WAL checkpoint
# DB_SQLITE_PRAGMA__JOURNAL_MODE=WAL
# DB_SQLITE_PRAGMA__WAL_AUTOCHECKPOINT=1000


# 或使用 PostgreSQL
# DB_CLIENT="pg"
# DB_HOST="localhost"
# DB_PORT="5432"
# DB_DATABASE="directus"
# DB_USER="postgres"
# DB_PASSWORD="password"

# 伺服器配置
HOST="127.0.0.1"
PORT="8055"
PUBLIC_URL="http://localhost:8055"

# CORS 配置
CORS_ENABLED="true"
CORS_ORIGIN="http://localhost:5173,http://localhost:3000"

# 谨慎使用以下設置
#CONTENT_SECURITY_POLICY_DIRECTIVES=false

# 配置并重启 Directus 后，系统就会按照你的设定，自动且安全地清理旧数据
RETENTION_ENABLED="true"
ACTIVITY_RETENTION="30d"
REVISIONS_RETENTION="30d"
# 每周日凌晨3点
RETENTION_SCHEDULE="0 3 * * 0"

# Email 設定 (使用 Gmail SMTP)
EMAIL_FROM="cn27529h@gmail.com"
EMAIL_TRANSPORT="smtp"
EMAIL_SMTP_HOST="smtp.gmail.com"
EMAIL_SMTP_PORT="587"
EMAIL_SMTP_USER="cn27529h@gmail.com"
EMAIL_SMTP_PASSWORD="ostqydjsxptnvicf" # 第三方寄信服務應用程式密碼
EMAIL_SMTP_SECURE="false"  # 使用 STARTTLS 時設為 false
EMAIL_SMTP_IGNORE_TLS="false"



